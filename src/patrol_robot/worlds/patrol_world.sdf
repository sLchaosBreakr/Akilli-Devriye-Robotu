<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="patrol_world">
    
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <!-- Aydınlatma -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 15 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.4 0.2 -0.9</direction>
    </light>

    <light type="point" name="light1">
      <pose>0 2 3.5 0 0 0</pose>
      <diffuse>0.8 0.8 0.7 1</diffuse>
      <attenuation><range>15</range><constant>0.3</constant><linear>0.05</linear></attenuation>
    </light>

    <light type="point" name="light2">
      <pose>4 2 3.5 0 0 0</pose>
      <diffuse>0.8 0.8 0.7 1</diffuse>
      <attenuation><range>15</range><constant>0.3</constant><linear>0.05</linear></attenuation>
    </light>

    <!-- Zemin - Beton -->
    <model name="ground">
      <static>true</static>
      <link name="link">
        <collision name="c"><geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry></collision>
        <visual name="v"><geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Depo Zemini -->
    <model name="floor">
      <static>true</static>
      <pose>0 1 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>16 12 0.01</size></box></geometry>
          <material><ambient>0.5 0.5 0.48 1</ambient><diffuse>0.6 0.6 0.58 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Sarı Zemin Çizgileri -->
    <model name="line1">
      <static>true</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>14 0.08 0.01</size></box></geometry>
        <material><ambient>0.9 0.8 0 1</ambient><diffuse>1 0.9 0 1</diffuse></material></visual></link>
    </model>
    <model name="line2">
      <static>true</static>
      <pose>0 4 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>14 0.08 0.01</size></box></geometry>
        <material><ambient>0.9 0.8 0 1</ambient><diffuse>1 0.9 0 1</diffuse></material></visual></link>
    </model>

    <!-- Ana Duvarlar -->
    <model name="wall_n">
      <static>true</static>
      <pose>0 6 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>16 0.25 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.25 3</size></box></geometry>
          <material><ambient>0.75 0.73 0.7 1</ambient><diffuse>0.85 0.83 0.8 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_s">
      <static>true</static>
      <pose>0 -4 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>16 0.25 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.25 3</size></box></geometry>
          <material><ambient>0.75 0.73 0.7 1</ambient><diffuse>0.85 0.83 0.8 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_e">
      <static>true</static>
      <pose>8 1 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.25 10 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.25 10 3</size></box></geometry>
          <material><ambient>0.75 0.73 0.7 1</ambient><diffuse>0.85 0.83 0.8 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_w">
      <static>true</static>
      <pose>-8 1 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.25 10 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.25 10 3</size></box></geometry>
          <material><ambient>0.75 0.73 0.7 1</ambient><diffuse>0.85 0.83 0.8 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Depo Rafları -->
    <model name="shelf1">
      <static>true</static>
      <pose>5.5 4.5 0 0 0 0</pose>
      <link name="link">
        <collision name="c"><pose>0 0 0.75 0 0 0</pose><geometry><box><size>2 0.5 1.5</size></box></geometry></collision>
        <visual name="frame1"><pose>-0.9 -0.2 0.75 0 0 0</pose><geometry><box><size>0.06 0.06 1.5</size></box></geometry>
          <material><ambient>0.3 0.35 0.5 1</ambient></material></visual>
        <visual name="frame2"><pose>0.9 -0.2 0.75 0 0 0</pose><geometry><box><size>0.06 0.06 1.5</size></box></geometry>
          <material><ambient>0.3 0.35 0.5 1</ambient></material></visual>
        <visual name="frame3"><pose>-0.9 0.2 0.75 0 0 0</pose><geometry><box><size>0.06 0.06 1.5</size></box></geometry>
          <material><ambient>0.3 0.35 0.5 1</ambient></material></visual>
        <visual name="frame4"><pose>0.9 0.2 0.75 0 0 0</pose><geometry><box><size>0.06 0.06 1.5</size></box></geometry>
          <material><ambient>0.3 0.35 0.5 1</ambient></material></visual>
        <visual name="plank1"><pose>0 0 0.4 0 0 0</pose><geometry><box><size>1.9 0.5 0.04</size></box></geometry>
          <material><ambient>0.5 0.4 0.3 1</ambient></material></visual>
        <visual name="plank2"><pose>0 0 1.0 0 0 0</pose><geometry><box><size>1.9 0.5 0.04</size></box></geometry>
          <material><ambient>0.5 0.4 0.3 1</ambient></material></visual>
      </link>
    </model>

    <!-- Kutular raf üstünde -->
    <model name="box1">
      <static>true</static>
      <pose>5.2 4.5 0.55 0 0 0.1</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.35 0.3 0.25</size></box></geometry>
        <material><ambient>0.6 0.45 0.25 1</ambient><diffuse>0.75 0.6 0.4 1</diffuse></material></visual></link>
    </model>
    <model name="box2">
      <static>true</static>
      <pose>5.8 4.5 0.55 0 0 -0.05</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.3 0.25</size></box></geometry>
        <material><ambient>0.55 0.4 0.2 1</ambient><diffuse>0.7 0.55 0.35 1</diffuse></material></visual></link>
    </model>

    <!-- Forklift -->
    <model name="forklift">
      <static>true</static>
      <pose>-6 4.5 0 0 0 0.5</pose>
      <link name="link">
        <collision name="c"><pose>0 0 0.5 0 0 0</pose><geometry><box><size>1.5 0.8 1</size></box></geometry></collision>
        <visual name="body"><pose>0 0 0.35 0 0 0</pose><geometry><box><size>1.0 0.7 0.5</size></box></geometry>
          <material><ambient>0.9 0.5 0 1</ambient><diffuse>1 0.6 0 1</diffuse></material></visual>
        <visual name="cabin"><pose>-0.1 0 0.75 0 0 0</pose><geometry><box><size>0.6 0.6 0.5</size></box></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient></material></visual>
        <visual name="mast"><pose>0.55 0 0.6 0 0 0</pose><geometry><box><size>0.08 0.4 1.0</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <visual name="fork1"><pose>0.85 -0.15 0.12 0 0 0</pose><geometry><box><size>0.6 0.06 0.04</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <visual name="fork2"><pose>0.85 0.15 0.12 0 0 0</pose><geometry><box><size>0.6 0.06 0.04</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <visual name="w1"><pose>0.3 0.4 0.15 1.57 0 0</pose><geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
        <visual name="w2"><pose>0.3 -0.4 0.15 1.57 0 0</pose><geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
    </model>

    <!-- Paletler ve Kutular -->
    <model name="pallet1">
      <static>true</static>
      <pose>6 -2 0.08 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>1.2 1 0.15</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.2 1 0.15</size></box></geometry>
          <material><ambient>0.55 0.45 0.3 1</ambient><diffuse>0.7 0.6 0.45 1</diffuse></material></visual>
      </link>
    </model>
    <model name="crate1">
      <static>true</static>
      <pose>6 -2 0.4 0 0 0.1</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>0.6 0.5 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.6 0.5 0.5</size></box></geometry>
          <material><ambient>0.6 0.5 0.35 1</ambient><diffuse>0.75 0.65 0.5 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Güvenlik Masası -->
    <model name="desk">
      <static>true</static>
      <pose>-6 -2.5 0 0 0 0</pose>
      <link name="link">
        <collision name="c"><pose>0 0 0.35 0 0 0</pose><geometry><box><size>1.2 0.6 0.7</size></box></geometry></collision>
        <visual name="top"><pose>0 0 0.38 0 0 0</pose><geometry><box><size>1.2 0.6 0.04</size></box></geometry>
          <material><ambient>0.4 0.3 0.2 1</ambient><diffuse>0.55 0.45 0.35 1</diffuse></material></visual>
        <visual name="leg1"><pose>-0.5 -0.2 0.18 0 0 0</pose><geometry><box><size>0.04 0.04 0.36</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient></material></visual>
        <visual name="leg2"><pose>0.5 -0.2 0.18 0 0 0</pose><geometry><box><size>0.04 0.04 0.36</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient></material></visual>
        <visual name="leg3"><pose>-0.5 0.2 0.18 0 0 0</pose><geometry><box><size>0.04 0.04 0.36</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient></material></visual>
        <visual name="leg4"><pose>0.5 0.2 0.18 0 0 0</pose><geometry><box><size>0.04 0.04 0.36</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient></material></visual>
      </link>
    </model>

    <!-- Monitör -->
    <model name="monitor">
      <static>true</static>
      <pose>-6 -2.3 0.55 0 0 0</pose>
      <link name="l">
        <visual name="screen"><geometry><box><size>0.4 0.03 0.28</size></box></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.2 1</diffuse></material></visual>
        <visual name="stand"><pose>0 -0.02 -0.18 0 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient></material></visual>
      </link>
    </model>

    <!-- YASAK BÖLGE A - Kasa Odası -->
    <model name="zone_a_floor">
      <static>true</static>
      <pose>3 3 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>2 2 0.02</size></box></geometry>
        <material><ambient>0.9 0.1 0.1 1</ambient><diffuse>1 0.2 0.2 1</diffuse></material></visual></link>
    </model>
    <model name="zone_a_border1">
      <static>true</static>
      <pose>3 4.05 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>2.2 0.1 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>
    <model name="zone_a_border2">
      <static>true</static>
      <pose>3 1.95 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>2.2 0.1 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>
    <model name="zone_a_border3">
      <static>true</static>
      <pose>4.05 3 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.1 2.2 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>
    <model name="zone_a_border4">
      <static>true</static>
      <pose>1.95 3 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.1 2.2 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>

    <!-- Kasa -->
    <model name="safe">
      <static>true</static>
      <pose>3 3.3 0.35 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>0.5 0.4 0.7</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.5 0.4 0.7</size></box></geometry>
          <material><ambient>0.25 0.25 0.27 1</ambient><diffuse>0.35 0.35 0.38 1</diffuse><specular>0.4 0.4 0.4 1</specular></material></visual>
      </link>
    </model>

    <!-- YASAK BÖLGE B - Sunucu Odası -->
    <model name="zone_b_floor">
      <static>true</static>
      <pose>-4 -2 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>2 2 0.02</size></box></geometry>
        <material><ambient>0.9 0.1 0.1 1</ambient><diffuse>1 0.2 0.2 1</diffuse></material></visual></link>
    </model>
    <model name="zone_b_border1">
      <static>true</static>
      <pose>-4 -0.95 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>2.2 0.1 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>
    <model name="zone_b_border2">
      <static>true</static>
      <pose>-4 -3.05 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>2.2 0.1 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>
    <model name="zone_b_border3">
      <static>true</static>
      <pose>-2.95 -2 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.1 2.2 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>
    <model name="zone_b_border4">
      <static>true</static>
      <pose>-5.05 -2 0.03 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.1 2.2 0.06</size></box></geometry>
        <material><ambient>0.9 0.75 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material></visual></link>
    </model>

    <!-- Server Rack -->
    <model name="server">
      <static>true</static>
      <pose>-4.3 -2 0.8 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>0.5 0.7 1.6</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.5 0.7 1.6</size></box></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material></visual>
        <visual name="led"><pose>0.26 0 0.2 0 0 0</pose><geometry><box><size>0.01 0.3 0.04</size></box></geometry>
          <material><ambient>0 0.8 0 1</ambient><diffuse>0 1 0 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Waypoints -->
    <model name="wp1"><static>true</static><pose>0 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.25</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0 0.8 0 1</ambient><diffuse>0 1 0 1</diffuse></material></visual></link></model>
    <model name="wp2"><static>true</static><pose>4 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.25</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0 0.6 0.9 1</ambient></material></visual></link></model>
    <model name="wp3"><static>true</static><pose>4 4 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.25</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0 0.6 0.9 1</ambient></material></visual></link></model>
    <model name="wp4"><static>true</static><pose>-4 4 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.25</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0 0.6 0.9 1</ambient></material></visual></link></model>
    <model name="wp5"><static>true</static><pose>-4 -2 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.25</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0 0.6 0.9 1</ambient></material></visual></link></model>

    <!-- ROBOT - Aynı kalacak -->
    <model name="patrol_robot">
      <pose>0 0 0.05 0 0 0</pose>
      
      <link name="base_link">
        <inertial>
          <mass>5.0</mass>
          <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz></inertia>
        </inertial>
        <collision name="c">
          <geometry><cylinder><radius>0.15</radius><length>0.1</length></cylinder></geometry>
        </collision>
        <visual name="v">
          <geometry><cylinder><radius>0.15</radius><length>0.1</length></cylinder></geometry>
          <material><ambient>0 0 0.8 1</ambient><diffuse>0 0 1 1</diffuse></material>
        </visual>
        <visual name="top">
          <pose>0 0 0.08 0 0 0</pose>
          <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.2 1</ambient><diffuse>0.15 0.15 0.3 1</diffuse></material>
        </visual>
        <visual name="light">
          <pose>0 0 0.12 0 0 0</pose>
          <geometry><cylinder><radius>0.02</radius><length>0.03</length></cylinder></geometry>
          <material><ambient>0 0.5 1 1</ambient><diffuse>0 0.7 1 1</diffuse></material>
        </visual>
      </link>

      <link name="left_wheel">
        <pose>0 0.17 0 -1.5707 0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
        <collision name="c">
          <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
      </link>

      <link name="right_wheel">
        <pose>0 -0.17 0 -1.5707 0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
        <collision name="c">
          <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
      </link>

      <link name="caster">
        <pose>-0.1 0 -0.025 0 0 0</pose>
        <inertial><mass>0.1</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
        <collision name="c">
          <geometry><sphere><radius>0.025</radius></sphere></geometry>
          <surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><sphere><radius>0.025</radius></sphere></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent><child>left_wheel</child>
        <axis><xyz>0 0 1</xyz></axis>
      </joint>
      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent><child>right_wheel</child>
        <axis><xyz>0 0 1</xyz></axis>
      </joint>
      <joint name="caster_joint" type="ball">
        <parent>base_link</parent><child>caster</child>
      </joint>

      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.34</wheel_separation>
        <wheel_radius>0.05</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
      </plugin>
    </model>

  </world>
</sdf>
